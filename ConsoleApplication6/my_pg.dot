digraph G { 0 -> 1 [label="i = 0"]
1 -> 3 [label="i < length"]
1 -> 13 [label="! (i < length)"]
3 -> 5 [label="arr[i] < 0"]
3 -> 11 [label="! (arr[i] < 0)"]
5 -> 6 [label="j = 1"]
6 -> 8 [label="j <= - (arr[i])"]
6 -> 11 [label="! (j <= - (arr[i]))"]
8 -> 9 [label="arr[i + j] = - (arr[i])"]
9 -> 6 [label="j = j + 1"]
11 -> 1 [label="i = i + 1"]
}